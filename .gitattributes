# Auto detect text files and normalize line endings to LF
* text=auto

# Dart files
*.dart text eol=lf

# Gradle files
*.gradle text eol=lf
*.gradle.kts text eol=lf
gradlew text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# JSON
*.json text eol=lf

# YAML
*.yaml text eol=lf
*.yml text eol=lf

# Markdown
*.md text eol=lf

# Text
*.txt text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.apk binary
*.ipa binary
*.app binary
*.elf binary
*.db binary
